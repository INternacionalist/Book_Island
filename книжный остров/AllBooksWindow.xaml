<Window x:Class="WpfAppBookStore.AllBooksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Все книги" Height="600" Width="980" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <TextBox x:Name="SearchBox" Height="32" Margin="0,0,0,10" DockPanel.Dock="Top" TextChanged="SearchBox_TextChanged" ToolTip="Поиск по названию"/>
        <DataGrid x:Name="BooksGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding BookID}" Width="70"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author}" Width="220"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="140"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N0} ₽}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
