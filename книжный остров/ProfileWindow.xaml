<Window x:Class="WpfAppBookStore.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль" Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        MinWidth="460"
        MinHeight="500"
        Background="#F2F6FF">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20">
        <Border Background="White" CornerRadius="20" Padding="28">
            <StackPanel>
                <TextBlock Text="Профиль" FontSize="30" FontWeight="Bold" Foreground="#1A2550"/>
                <TextBlock Text="Данные аккаунта" Foreground="#64729A" Margin="0,8,0,22"/>

                <Border Background="#EAF0FF" CornerRadius="14" Padding="16" Margin="0,0,0,12" Cursor="Hand" MouseLeftButtonUp="CopyCard_MouseLeftButtonUp" Tag="UserNameText">
                    <StackPanel>
                        <TextBlock Text="Имя" FontSize="13" Foreground="#64729A"/>
                        <TextBlock x:Name="UserNameText" FontSize="24" FontWeight="SemiBold" Foreground="#1A2550"/>
                    </StackPanel>
                </Border>

                <Border Background="#EAF0FF" CornerRadius="14" Padding="16" Margin="0,0,0,12" Cursor="Hand" MouseLeftButtonUp="CopyCard_MouseLeftButtonUp" Tag="LastNameText">
                    <StackPanel>
                        <TextBlock Text="Фамилия" FontSize="13" Foreground="#64729A"/>
                        <TextBlock x:Name="LastNameText" FontSize="20" FontWeight="SemiBold" Foreground="#1A2550"/>
                    </StackPanel>
                </Border>

                <Border Background="#EAF0FF" CornerRadius="14" Padding="16" Margin="0,0,0,12" Cursor="Hand" MouseLeftButtonUp="CopyCard_MouseLeftButtonUp" Tag="PhoneText">
                    <StackPanel>
                        <TextBlock Text="Номер телефона" FontSize="13" Foreground="#64729A"/>
                        <TextBlock x:Name="PhoneText" FontSize="20" FontWeight="SemiBold" Foreground="#1A2550"/>
                    </StackPanel>
                </Border>

                <Border Background="#EAF0FF" CornerRadius="14" Padding="16" Margin="0,0,0,18" Cursor="Hand" MouseLeftButtonUp="CopyCard_MouseLeftButtonUp" Tag="UserIdText">
                    <StackPanel>
                        <TextBlock Text="ID (дата регистрации)" FontSize="13" Foreground="#64729A"/>
                        <TextBlock x:Name="UserIdText" FontSize="20" FontWeight="SemiBold" Foreground="#1A2550" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="#EAF0FF" CornerRadius="14" Padding="16" Margin="0,0,0,18" Cursor="Hand" MouseLeftButtonUp="CopyCard_MouseLeftButtonUp" Tag="AddressText">
                    <StackPanel>
                        <TextBlock Text="Адрес доставки" FontSize="13" Foreground="#64729A"/>
                        <TextBlock x:Name="AddressText" FontSize="16" FontWeight="SemiBold" Foreground="#1A2550" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Button Content="Закрыть" Height="42" Width="120" HorizontalAlignment="Right" Background="#4B6BFB" Foreground="White" BorderThickness="0" Click="Close_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
