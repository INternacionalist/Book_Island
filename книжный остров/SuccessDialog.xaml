<Window x:Class="WpfAppBookStore.SuccessDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Успех" Height="240" Width="280"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="White" Topmost="True" WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#4CAF50" BorderThickness="3" CornerRadius="15" Background="White">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">

            <TextBlock Text="✓" HorizontalAlignment="Center" 
                       FontSize="48" Foreground="#4CAF50" Margin="0,0,0,15"/>

            <TextBlock x:Name="MessageText" HorizontalAlignment="Center" 
                       FontSize="16" FontWeight="Bold" Foreground="#333" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <Button Content="OK" Height="35" Width="120"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="13"
                    Click="OkBtn_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border BorderThickness="0" CornerRadius="6" 
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45a049"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>