<Window x:Class="WpfAppBookStore.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Админ-панель" Height="760" Width="980" WindowStartupLocation="CenterOwner" Background="#F2F6FF">
    <ScrollViewer>
    <StackPanel Margin="16">
        <Border Background="White" CornerRadius="18" Padding="16">
            <StackPanel>
                <TextBlock Text="Публикация книги" FontSize="22" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1A2550"/>
                <WrapPanel>
                    <TextBox x:Name="TitleBox" Width="220" Height="34" Margin="0,0,8,8" ToolTip="Название"/>
                    <TextBox x:Name="AuthorBox" Width="180" Height="34" Margin="0,0,8,8" ToolTip="Автор"/>
                    <TextBox x:Name="GenreBox" Width="140" Height="34" Margin="0,0,8,8" ToolTip="Жанр"/>
                    <TextBox x:Name="PriceBox" Width="100" Height="34" Margin="0,0,8,8" ToolTip="Цена"/>
                </WrapPanel>
                <TextBox x:Name="DescriptionBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8" ToolTip="Описание"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Выбрать обложку" Height="36" Padding="12,0" Click="PickCover_Click" Margin="0,0,8,0"/>
                    <TextBlock x:Name="CoverPathText" VerticalAlignment="Center" Foreground="#667085"/>
                    <Button Content="Опубликовать" Height="36" Padding="12,0" Click="Publish_Click" Margin="12,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Background="White" CornerRadius="18" Padding="16" Margin="0,14,0,0">
            <StackPanel>
                <TextBlock Text="Удаление книги" FontSize="20" FontWeight="Bold" Foreground="#1A2550"/>
                <TextBox x:Name="BookSearchBox" Height="34" Margin="0,8,0,8" TextChanged="BookSearchBox_TextChanged" ToolTip="Поиск книги"/>
                <DataGrid x:Name="BooksGrid" Height="220" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding BookID}" Width="80"/>
                        <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                        <DataGridTemplateColumn Header="Действие" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate><Button Content="Удалить" Tag="{Binding BookID}" Click="DeleteBook_Click"/></DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <Border Background="White" CornerRadius="18" Padding="16" Margin="0,14,0,0">
            <StackPanel>
                <TextBlock Text="Пользователи" FontSize="20" FontWeight="Bold" Foreground="#1A2550"/>
                <TextBox x:Name="UserSearchBox" Height="34" Margin="0,8,0,8" TextChanged="UserSearchBox_TextChanged" ToolTip="Поиск пользователя"/>
                <DataGrid x:Name="UsersGrid" Height="220" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*"/>
                        <DataGridTemplateColumn Header="Действие" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate><Button Content="Удалить" Tag="{Binding Id}" Click="DeleteUser_Click"/></DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</Window>
