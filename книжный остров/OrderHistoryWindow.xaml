<Window x:Class="WpfAppBookStore.OrderHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История заказов" Height="500" Width="760" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <DataGrid x:Name="OrdersGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding OrderId}" Width="80"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt}" Width="160"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" Width="130"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding AddressLine}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
