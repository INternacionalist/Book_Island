<Window x:Class="WpfAppBookStore.OrderHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История заказов" Height="560" Width="900" WindowStartupLocation="CenterOwner" Background="#F2F6FF">
    <Grid Margin="16">
        <Border Background="White" CornerRadius="18" Padding="16">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Text="История заказов" FontSize="26" FontWeight="Bold" Foreground="#1A2550" Margin="0,0,0,12"/>
                <DataGrid Grid.Row="1" x:Name="OrdersGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" BorderThickness="0" Background="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding OrderId}" Width="80"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt}" Width="180"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" Width="130"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="130"/>
                        <DataGridTextColumn Header="Адрес" Binding="{Binding AddressLine}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
