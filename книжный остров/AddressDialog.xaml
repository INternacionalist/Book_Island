<Window x:Class="WpfAppBookStore.AddressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Адрес доставки" Height="370" Width="560" WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <TextBox x:Name="CityBox" Margin="4" Height="30" VerticalContentAlignment="Center" ToolTip="Город"/>
            <TextBox x:Name="DistrictBox" Grid.Column="1" Margin="4" Height="30" VerticalContentAlignment="Center" ToolTip="Район"/>
            <TextBox x:Name="StreetBox" Grid.Row="1" Grid.ColumnSpan="2" Margin="4" Height="30" VerticalContentAlignment="Center" ToolTip="Улица"/>
            <TextBox x:Name="HouseBox" Grid.Row="2" Margin="4" Height="30" VerticalContentAlignment="Center" ToolTip="Дом"/>
            <TextBox x:Name="ApartmentBox" Grid.Row="2" Grid.Column="1" Margin="4" Height="30" VerticalContentAlignment="Center" ToolTip="Квартира (опционально)"/>
            <TextBox x:Name="IntercomBox" Grid.Row="3" Margin="4" Height="30" VerticalContentAlignment="Center" ToolTip="Домофон (опционально)"/>
            <TextBox x:Name="FloorBox" Grid.Row="3" Grid.Column="1" Margin="4" Height="30" VerticalContentAlignment="Center" ToolTip="Этаж (опционально)"/>
            <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Margin="4,12,4,0" Foreground="#667085" Text="Поля: город, район, улица, дом — обязательные."/>
        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Отмена" Width="100" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Оформить" Width="100" Click="Submit_Click"/>
        </StackPanel>
    </Grid>
</Window>
