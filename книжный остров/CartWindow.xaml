<Window x:Class="WpfAppBookStore.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Корзина" Height="620" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F2F4F8"
        MinWidth="760"
        MinHeight="520"
        PreviewMouseDown="Window_PreviewMouseDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="SelectionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="26" Height="26">
                            <Border x:Name="SelectionBorder" Background="#F4F6FF" BorderBrush="#D0D8F5" BorderThickness="1.5" CornerRadius="4"/>
                            <TextBlock x:Name="SelectionIcon" Text="✓" FontSize="14" FontWeight="Bold" Foreground="#A3AED0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Background" Value="#4B6BFB"/>
                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#3553D8"/>
                                <Setter TargetName="SelectionIcon" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#5A79FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectAllButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#4B6BFB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3553D8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#EEF2F8"/>
            <Setter Property="Foreground" Value="#1D2939"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FDEBED"/>
                    <Setter Property="Foreground" Value="#D92D20"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="20" MinWidth="700">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#F9FAFD" CornerRadius="20" Padding="18,14" BorderBrush="#E8ECF4" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="SelectAllButton" Content="Выбрать все" Style="{StaticResource SelectAllButtonStyle}" VerticalAlignment="Center" Click="SelectAllButton_Click"/>
                <TextBlock Grid.Column="1" Text="🛒" FontSize="24" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,14" Background="#FBFCFE" CornerRadius="20" BorderBrush="#E8ECF4" BorderThickness="1" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                    <Border Background="#EDF1F8" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="30" Height="30" CornerRadius="4" Background="#DDE7FF" Margin="0,0,10,0">
                                <TextBlock Text="✓" FontWeight="Bold" Foreground="#3553D8" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Доступны для заказа" FontWeight="SemiBold" Foreground="#1D2939" FontSize="22" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" CanContentScroll="True" PanningMode="VerticalOnly">
                    <ItemsControl x:Name="CartItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#E8ECF4" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" Style="{StaticResource SelectionCheckBoxStyle}" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Top" Margin="0,4,12,0" Checked="ItemSelectionCheckBox_Changed" Unchecked="ItemSelectionCheckBox_Changed"/>

                                        <Border Grid.Column="1" Height="90" Width="70" CornerRadius="10" Background="#EDF1F8" ClipToBounds="True">
                                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="2" Margin="14,0,18,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" Foreground="#101828" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Author}" Foreground="#667085" Margin="0,2,0,4"/>
                                            <TextBlock Text="{Binding Description}" Foreground="#475467" FontSize="13" TextTrimming="CharacterEllipsis" MaxWidth="320" Cursor="Hand" MouseLeftButtonUp="DescriptionTextBlock_MouseLeftButtonUp" ToolTip="Нажмите, чтобы развернуть описание"/>
                                            <Border Background="#FFE6F1" Padding="8,2" CornerRadius="7" HorizontalAlignment="Left"
                                                    Visibility="{Binding HasBulkDiscount, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="% Скидка от 2 ед" Foreground="#D21A74" FontWeight="SemiBold" FontSize="12"/>
                                            </Border>
                                        </StackPanel>

                                        <Border Grid.Column="3" Background="#EEF2F8" CornerRadius="10" Padding="6" VerticalAlignment="Center" Margin="0,0,20,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42"/>
                                                    <ColumnDefinition Width="42"/>
                                                    <ColumnDefinition Width="42"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="−" FontSize="22" FontWeight="Bold" Tag="{Binding}" Click="DecreaseQuantityButton_Click" BorderThickness="0" Background="Transparent" Cursor="Hand"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Quantity}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
                                                <Button Grid.Column="2" Content="+" FontSize="22" FontWeight="Bold" Tag="{Binding}" Click="IncreaseQuantityButton_Click" BorderThickness="0" Background="Transparent" Cursor="Hand"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:N0} ₽}" Foreground="#00A651" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding OriginalTotalPrice, StringFormat={}{0:N0} ₽}" Foreground="#98A2B3" FontSize="15" HorizontalAlignment="Right"
                                                       TextDecorations="Strikethrough"
                                                       Visibility="{Binding HasBulkDiscount, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <Button Grid.Column="5" Content="🗑" Style="{StaticResource DeleteButtonStyle}" Tag="{Binding}" Click="RemoveItemButton_Click" VerticalAlignment="Center"/>

                                        <Popup IsOpen="{Binding IsDescriptionExpanded}" Placement="Center" StaysOpen="True" AllowsTransparency="True">
                                            <Border Background="#F8FAFF" BorderBrush="#CFD8F6" BorderThickness="1" CornerRadius="12" Padding="14" Width="460">
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#344054" FontSize="14"/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E8ECF4" BorderThickness="1" CornerRadius="16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Итог по выбранным" FontSize="18" FontWeight="SemiBold" Foreground="#1D2939" VerticalAlignment="Center"/>
                <TextBlock x:Name="SelectedTotalText" Grid.Column="1" FontSize="28" FontWeight="Bold" Foreground="#4B6BFB" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Grid.Column="2" Content="Оформить заказ" Style="{StaticResource SelectAllButtonStyle}" Width="180" Height="44" Click="PlaceOrderButton_Click"/>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
