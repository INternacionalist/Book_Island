<Window x:Class="WpfAppBookStore.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Корзина" Height="640" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F2F4F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="18" Padding="18" Margin="0,0,0,14">
            <DockPanel>
                <CheckBox x:Name="SelectAllCheckBox" Content="Выбрать все" FontSize="22" VerticalAlignment="Center" IsChecked="True" Checked="SelectAllCheckBox_Changed" Unchecked="SelectAllCheckBox_Changed"/>
                <Button DockPanel.Dock="Right" Content="Закрыть" Width="120" Height="38" Background="#EAF0FF" BorderThickness="0" FontWeight="SemiBold" Click="Close_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="18" Padding="18" BorderBrush="#E0E5EF" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#F4F6FA" CornerRadius="12" Padding="12" Margin="0,0,0,14">
                    <TextBlock Text="Доступны для заказа" FontSize="22" FontWeight="SemiBold"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CartItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EDF1F7" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" VerticalAlignment="Top" Margin="0,4,12,0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Checked="ItemCheckBox_Changed" Unchecked="ItemCheckBox_Changed"/>
                                        <Border Grid.Column="1" Width="74" Height="96" CornerRadius="10" Background="#EEF2FF">
                                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel Grid.Column="2" Margin="14,2,14,0">
                                            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <Border Background="#FFF0F7" CornerRadius="8" Padding="8,3" Margin="0,10,0,0" HorizontalAlignment="Left">
                                                <TextBlock Text="% Скидка от 2 ед" Foreground="#D31577" FontWeight="SemiBold" FontSize="13"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Margin="4,4,24,0" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding CurrentPrice, StringFormat={}{0:0.##} ₽}" Foreground="#00A041" FontWeight="Bold" FontSize="24"/>
                                            <TextBlock Text="{Binding OldPrice, StringFormat={}{0:0.##} ₽}" Foreground="#8B94A7" FontSize="16">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextDecorations" Value="{x:Null}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Grid.Column="4" Background="#F2F4F8" CornerRadius="12" Height="44" VerticalAlignment="Top">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="−" FontSize="20" Background="Transparent" BorderThickness="0" FontWeight="Bold" Tag="{Binding}" Click="Decrease_Click"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Quantity}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold"/>
                                                <Button Grid.Column="2" Content="+" FontSize="20" Background="Transparent" BorderThickness="0" FontWeight="Bold" Tag="{Binding}" Click="Increase_Click"/>
                                            </Grid>
                                        </Border>

                                        <Button Grid.Column="5" Content="🗑" Width="42" Height="42" Margin="10,0,0,0" VerticalAlignment="Top" Background="#F4F6FA" BorderThickness="0" Tag="{Binding}" Click="Remove_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <TextBlock x:Name="EmptyText" Grid.Row="2" Text="Корзина пуста. Добавьте книги из каталога." FontSize="16" Foreground="#6B7489" Margin="6,12,0,0"/>
    </Grid>
</Window>
