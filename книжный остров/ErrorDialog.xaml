<Window x:Class="WpfAppBookStore.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ошибка" Height="231" Width="259"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="White" Topmost="True" WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#F44336" BorderThickness="3" CornerRadius="15" Background="White">
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,23,0,0">

            <TextBlock Text="✕" HorizontalAlignment="Center" 
                       FontSize="48" Foreground="#F44336" Margin="0,0,0,15"/>

            <TextBlock x:Name="MessageText" HorizontalAlignment="Center" 
                       FontSize="16" FontWeight="Bold" Foreground="#333" TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,0,0,20"/>
            <Button Content="ОК" Height="44" Width="120"
                Background="#F44336" Foreground="White" FontWeight="Bold" FontSize="13"
                Click="OkBtn_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border BorderThickness="0" CornerRadius="6" 
                            Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#da190b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>