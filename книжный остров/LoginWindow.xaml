<Window x:Class="WpfAppBookStore.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="560" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F2F6FF" Topmost="True">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4B6BFB"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#3553D8"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#182033"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#65708A"/>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#D6DDF4"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E9EEFF"/>
            <Setter Property="Foreground" Value="#3553D8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DAE4FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border Background="White" CornerRadius="20" Padding="24" BorderBrush="#E3E9FB" BorderThickness="1">
            <Grid>
                <StackPanel x:Name="LoginPanel" VerticalAlignment="Center">
                    <TextBlock Text="Вход" HorizontalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>
                    <TextBlock Text="Используйте логин и пароль аккаунта" HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,24"/>

                    <TextBlock Text="Логин" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="UserLogin" Padding="10,8" BorderThickness="0" FontSize="14" Background="Transparent"/>
                    </Border>

                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,18">
                        <PasswordBox x:Name="UserPass" Padding="10,8" BorderThickness="0" FontSize="14" Background="Transparent"/>
                    </Border>

                    <Button Content="Войти" Margin="0,0,0,10" Style="{StaticResource PrimaryButtonStyle}" Click="LoginBtn_Click"/>
                    <Button Content="Создать аккаунт" Style="{StaticResource SecondaryButtonStyle}" Click="OpenRegistrationBtn_Click"/>
                </StackPanel>

                <StackPanel x:Name="RegistrationPanel" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock Text="Регистрация" HorizontalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}"/>
                    <TextBlock Text="Заполните данные для нового аккаунта" HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,20"/>

                    <TextBlock Text="Имя (Login)" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="RegName" Padding="10,8" BorderThickness="0" FontSize="14" Background="Transparent"/>
                    </Border>

                    <TextBlock Text="Фамилия" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="RegLastName" Padding="10,8" BorderThickness="0" FontSize="14" Background="Transparent"/>
                    </Border>

                    <TextBlock Text="Номер телефона" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}">
                        <TextBox x:Name="RegPhone" Padding="10,8" BorderThickness="0" FontSize="14" Background="Transparent"/>
                    </Border>

                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                    <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,16">
                        <PasswordBox x:Name="RegPass" Padding="10,8" BorderThickness="0" FontSize="14" Background="Transparent"/>
                    </Border>

                    <Button Content="Зарегистрироваться" Margin="0,0,0,10" Style="{StaticResource PrimaryButtonStyle}" Click="RegBtn_Click"/>
                    <Button Content="Назад ко входу" Style="{StaticResource SecondaryButtonStyle}" Click="BackToLoginBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
