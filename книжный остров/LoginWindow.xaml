<Window x:Class="WpfAppBookStore.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="380" Width="320"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="White" Topmost="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="217*"/>
            <ColumnDefinition Width="103*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F0F8FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" Margin="30,0,30,0" Grid.ColumnSpan="2">

            <TextBlock Text="🔐 ВХОД" HorizontalAlignment="Center" 
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,25" Foreground="#333" Height="34"/>

            <!-- Логин -->
            <TextBlock Text="Логин:" Margin="0,0,0,6" FontSize="13" Foreground="#555" FontWeight="SemiBold"/>
            <Border BorderBrush="#333" BorderThickness="2" CornerRadius="6" Margin="0,0,0,12">
                <Border.Background>
                    <SolidColorBrush Color="White"/>
                </Border.Background>
                <TextBox x:Name="UserLogin" Padding="10,8" BorderThickness="0" FontSize="13"/>
            </Border>

            <!-- Пароль -->
            <TextBlock Text="Пароль:" Margin="0,0,0,6" FontSize="13" Foreground="#555" FontWeight="SemiBold"/>
            <Border BorderBrush="#333" BorderThickness="2" CornerRadius="6" Margin="0,0,0,18">
                <Border.Background>
                    <SolidColorBrush Color="White"/>
                </Border.Background>
                <PasswordBox x:Name="UserPass" Padding="10,8" BorderThickness="0" FontSize="13"/>
            </Border>

            <!-- Войти -->
            <Button Content="✓ ВОЙТИ" Margin="0,0,0,10" Height="40"
                    Background="#333" Foreground="White" FontWeight="Bold" FontSize="13"
                    Click="LoginBtn_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border BorderThickness="2" BorderBrush="#333" CornerRadius="6" 
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Регистрация -->
            <Button Content="+ РЕГИСТРАЦИЯ" Height="40"
                    Background="White" Foreground="#333" BorderBrush="#333" BorderThickness="2" 
                    FontWeight="Bold" FontSize="13"
                    Click="RegBtn_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border BorderThickness="2" BorderBrush="#333" CornerRadius="6" 
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>