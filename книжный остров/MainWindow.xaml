<Window x:Class="WpfAppBookStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин Книг" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BuyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E85D2A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D04D1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F5F5F5" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Width="50" Height="50" Background="Transparent"
                        BorderThickness="2" BorderBrush="#333" Margin="0,0,20,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderBrush="#333" BorderThickness="2" CornerRadius="8">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Border Grid.Column="1" Background="White" CornerRadius="25" BorderBrush="#DDD" BorderThickness="2" Height="50">
                    <TextBox x:Name="SearchBox"
                             Text="Поиск..."
                             VerticalAlignment="Center"
                             Padding="20,0"
                             FontSize="16"
                             BorderThickness="0"
                             GotFocus="SearchBox_GotFocus"
                             Foreground="#666"/>
                </Border>

                <Button x:Name="ThemeBtn" Grid.Column="2" Content="🌙 тема"
                        Width="100" Height="50" Margin="20,0,10,0"
                        Background="Transparent" BorderBrush="#333" BorderThickness="2"
                        FontSize="14" Cursor="Hand" Click="ThemeBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="3" Content="🛒 корзина"
                        Width="110" Height="50" Margin="0,0,10,0"
                        Background="Transparent" BorderBrush="#333" BorderThickness="2"
                        FontSize="14" Cursor="Hand" Click="CartButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="4" Content="👤 логин"
                        Width="100" Height="50"
                        Background="Transparent" BorderBrush="#333" BorderThickness="2"
                        FontSize="14" Cursor="Hand" Click="reg">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20">
                <StackPanel>
                    <Button Content="🔥 популярные ->"
                            HorizontalAlignment="Left"
                            Margin="10,20,0,20"
                            Background="Transparent"
                            BorderBrush="#333"
                            BorderThickness="2"
                            Padding="15,8"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <ItemsControl x:Name="BooksItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource BookCardStyle}" Width="250" Height="420">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="280"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="6" Margin="0,0,0,15">
                                            <Image Source="{Binding CoverURL}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="45" Margin="0,0,0,5" Foreground="#333"/>
                                            <TextBlock Text="{Binding Author}" FontSize="13" Foreground="#666" Margin="0,0,0,10"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" FontSize="20" FontWeight="Bold" Foreground="#FF6B35" VerticalAlignment="Center">
                                                    <Run Text="{Binding Price}"/>
                                                    <Run Text=" ₽" FontSize="16"/>
                                                </TextBlock>

                                                <Button Grid.Column="1"
                                                        Content="Купить"
                                                        Style="{StaticResource BuyButtonStyle}"
                                                        Click="BuyButton_Click"
                                                        Tag="{Binding BookID}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="CartPanel"
                    Width="420"
                    HorizontalAlignment="Right"
                    Margin="0,20,20,20"
                    Background="#F4F5F7"
                    BorderBrush="#E6E8EC"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="14"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="White" CornerRadius="14" Padding="12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="SelectAllCheckBox" Content="Выбрать все" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Click="SelectAllCheckBox_Click"/>
                            <Button Grid.Column="1" Content="✕" Width="34" Height="34" FontSize="15" FontWeight="Bold" Background="#EFF1F4" BorderThickness="0" Cursor="Hand" Click="CloseCartButton_Click"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CartItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="16" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="84"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Top" Margin="0,4,10,0" Checked="CartItemSelectionChanged" Unchecked="CartItemSelectionChanged"/>
                                            <Border Grid.Column="1" Width="74" Height="98" Background="#EEF0F4" CornerRadius="12" Margin="0,0,10,0">
                                                <Image Source="{Binding CoverURL}" Stretch="Uniform"/>
                                            </Border>

                                            <StackPanel Grid.Column="2" Margin="0,2,10,0">
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#1D2330" TextWrapping="Wrap"/>
                                                <TextBlock Text="✂ Скидка от 2 ед" FontSize="12" FontWeight="SemiBold" Foreground="#E7287F" Margin="0,4,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:F0} ₽}" FontSize="21" FontWeight="Bold" Foreground="#12B94A"/>
                                                    <TextBlock Text="{Binding OldTotalPrice, StringFormat={}{0:F0} ₽}" Margin="8,5,0,0" FontSize="14" Foreground="#9AA3B2" TextDecorations="Strikethrough">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasDiscount}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Content="🗑 удалить" Padding="10,5" Width="100" Margin="0,8,0,0" HorizontalAlignment="Left" Background="#EFF1F4" BorderThickness="0" Cursor="Hand" Click="RemoveCartItem_Click" Tag="{Binding BookID}"/>
                                            </StackPanel>

                                            <Border Grid.Column="3" Background="#EFF1F4" CornerRadius="16" Height="38" VerticalAlignment="Top" Padding="4,0">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="−" Width="30" Height="30" BorderThickness="0" Background="Transparent" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="DecreaseQuantity_Click" Tag="{Binding BookID}"/>
                                                    <TextBlock Text="{Binding Quantity}" Width="24" VerticalAlignment="Center" TextAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
                                                    <Button Content="+" Width="30" Height="30" BorderThickness="0" Background="Transparent" FontSize="18" FontWeight="Bold" Cursor="Hand" Click="IncreaseQuantity_Click" Tag="{Binding BookID}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock x:Name="CartSummaryText" FontSize="14" Foreground="#5A6475"/>
                            <TextBlock x:Name="CartTotalText" FontSize="24" FontWeight="Bold" Foreground="#1D2330"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
