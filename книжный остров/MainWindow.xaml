<Window x:Class="WpfAppBookStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книжный остров" Height="820" Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="#F2F6FF">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4B6BFB"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#3553D8"/>
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#E9EEFF"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#182033"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#65708A"/>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="400"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="4" Opacity="0.16" Color="#2A3D78"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.24" Color="#2A3D78"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BuyButtonStyle" TargetType="Button">
            <Setter Property="Content" Value="Купить"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=DataContext.IsInCart}" Value="True">
                    <Setter Property="Content" Value="В корзине"/>
                    <Setter Property="Background" Value="#00A651"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" From="0.92" To="1" Duration="0:0:0.18"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" From="0.92" To="1" Duration="0:0:0.18"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="16" Background="White" CornerRadius="20" Padding="20,14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.16" Color="#22346D"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="16" Height="54" VerticalAlignment="Center" BorderBrush="#D4DEFF" BorderThickness="1">
                        <TextBox x:Name="SearchBox"
                                 Margin="16,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="16"
                                 VerticalContentAlignment="Center"
                                 Foreground="{StaticResource TextMainBrush}"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Начните вводить название книги"/>
                    </Border>
                    <Popup x:Name="SearchSuggestionsPopup"
                           PlacementTarget="{Binding ElementName=SearchBox}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           VerticalOffset="8">
                        <Border Width="760" MaxHeight="260" Background="White" CornerRadius="14" BorderBrush="#D5DDF8" BorderThickness="1" Padding="10">
                            <ListBox x:Name="SearchSuggestionsList"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MouseDoubleClick="SearchSuggestionsList_MouseDoubleClick"
                                     SelectionChanged="SearchSuggestionsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="54"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Height="54" Width="42" CornerRadius="8" Background="#EEF2FF" ClipToBounds="True">
                                                <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}"/>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Author}" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource BuyButtonStyle}" Margin="12,0,0,0" Click="BuyButton_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                    <Button x:Name="CartButton" Width="56" Margin="0,0,10,0" Content="🛒" Style="{StaticResource HeaderActionButtonStyle}" Click="CartButton_Click"/>
                    <Button x:Name="ProfileButton" Width="132" Content="👤 Логин" Style="{StaticResource HeaderActionButtonStyle}" Click="ProfileButton_Click"/>
                    <Button x:Name="OrderHistoryButton" Width="120" Margin="10,0,0,0" Content="📦 История" Style="{StaticResource HeaderActionButtonStyle}" Click="OrderHistoryButton_Click" Visibility="Collapsed"/>
                    <Button x:Name="AdminButton" Width="120" Margin="10,0,0,0" Content="🛠 Админ" Style="{StaticResource HeaderActionButtonStyle}" Click="AdminButton_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,16">
            <StackPanel>
                <Border Margin="0,0,0,24" CornerRadius="20" Background="{StaticResource PrimaryBrush}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Книжный остров" Foreground="White" FontSize="34" FontWeight="Bold"/>
                        <TextBlock Text="Книги, жанры и обложки полностью загружаются из БД." Foreground="#E8EDFF" Margin="0,6,0,0" FontSize="14"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="📚 Все книги" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="4,0,0,12"/>
                <TextBlock Text="Показываем 5 книг. Нажмите «Смотреть все», чтобы открыть полный каталог." Foreground="{StaticResource TextMutedBrush}" Margin="4,0,0,14"/>

                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="" DockPanel.Dock="Left"/>
                    <Button Content="Смотреть все →" DockPanel.Dock="Right" Style="{StaticResource HeaderActionButtonStyle}" Width="170" Height="38" Click="OpenAllBooksButton_Click"/>
                </DockPanel>

                <ItemsControl x:Name="PopularBooksItemsControl" Margin="0,0,0,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BookCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="220"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" CornerRadius="12" Background="#EEF2FF">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="44" Foreground="{StaticResource TextMainBrush}"/>
                                        <TextBlock Text="{Binding Description}" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="34"/>
                                        <TextBlock Text="{Binding Author}" Margin="0,4,0,8" Foreground="{StaticResource TextMutedBrush}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}">
                                                <Run Text="{Binding Price}"/><Run Text=" ₽"/>
                                            </TextBlock>
                                            <Button Grid.Column="1" Style="{StaticResource BuyButtonStyle}" Click="BuyButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="🔥 Популярные книги" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="4,0,0,12"/>
                <ItemsControl x:Name="TopBooksItemsControl" Margin="0,0,0,24">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BookCardStyle}">
                                <Grid><Grid.RowDefinitions><RowDefinition Height="220"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" CornerRadius="12" Background="#EEF2FF"><Image Source="{Binding CoverImage}" Stretch="UniformToFill"/></Border>
                                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="44" Foreground="{StaticResource TextMainBrush}"/>
                                        <TextBlock Text="{Binding Description}" Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="34"/>
                                        <TextBlock Text="{Binding Author}" Margin="0,4,0,8" Foreground="{StaticResource TextMutedBrush}"/>
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"><Run Text="{Binding Price}"/><Run Text=" ₽"/></TextBlock>
                                            <Button Grid.Column="1" Style="{StaticResource BuyButtonStyle}" Click="BuyButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="📚 Жанры" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="4,0,0,12"/>
                <TextBlock Text="Жанры формируются автоматически из данных БД." Foreground="{StaticResource TextMutedBrush}" Margin="4,0,0,14"/>

                <ItemsControl x:Name="GenresItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="18" Padding="16" Margin="0,0,0,18" BorderBrush="#DDE4FF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding GenreName}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Books}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource BookCardStyle}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="220"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" Background="#EEF2FF" CornerRadius="12">
                                                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                                        </Border>
                                                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="44" Foreground="{StaticResource TextMainBrush}"/>
                                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="34" Margin="0,4,0,0"/>
                                                            <TextBlock Text="{Binding Author}" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,8"/>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}">
                                                                    <Run Text="{Binding Price}"/><Run Text=" ₽"/>
                                                                </TextBlock>
                                                                <Button Grid.Column="1" Style="{StaticResource BuyButtonStyle}" Click="BuyButton_Click"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
