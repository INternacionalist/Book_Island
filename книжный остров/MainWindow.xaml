<Window x:Class="WpfAppBookStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книжный остров" Height="820" Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="#F2F6FF">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4B6BFB"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#3553D8"/>
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#E9EEFF"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#182033"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#65708A"/>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="400"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="4" Opacity="0.16" Color="#2A3D78"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.24" Color="#2A3D78"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BuyButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="16" Background="White" CornerRadius="20" Padding="20,14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.16" Color="#22346D"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="16" Height="54" VerticalAlignment="Center" BorderBrush="#D4DEFF" BorderThickness="1">
                        <TextBox x:Name="SearchBox"
                                 Margin="16,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="16"
                                 VerticalContentAlignment="Center"
                                 Foreground="{StaticResource TextMainBrush}"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Начните вводить название книги"/>
                    </Border>
                    <Popup x:Name="SearchSuggestionsPopup"
                           PlacementTarget="{Binding ElementName=SearchBox}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           VerticalOffset="8">
                        <Border Width="760" MaxHeight="260" Background="White" CornerRadius="14" BorderBrush="#D5DDF8" BorderThickness="1" Padding="10">
                            <ListBox x:Name="SearchSuggestionsList"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MouseDoubleClick="SearchSuggestionsList_MouseDoubleClick"
                                     SelectionChanged="SearchSuggestionsList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}"/>
                                                <TextBlock Text="{Binding Author}" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="В корзину" Style="{StaticResource BuyButtonStyle}" Tag="{Binding BookID}" Margin="12,0,0,0" Click="BuyButton_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>

                <Button x:Name="ProfileButton" Grid.Column="1" Width="132" Margin="16,0,0,0" Content="👤 Логин" Style="{StaticResource HeaderActionButtonStyle}" Click="ProfileButton_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,16">
            <StackPanel>
                <Border Margin="0,0,0,24" CornerRadius="20" Background="{StaticResource PrimaryBrush}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Книжный остров" Foreground="White" FontSize="34" FontWeight="Bold"/>
                        <TextBlock Text="Подборки как в Читай-город: сначала популярные книги, ниже жанры и рекомендации." Foreground="#E8EDFF" Margin="0,6,0,0" FontSize="14"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="🔥 Популярные книги" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="4,0,0,12"/>
                <TextBlock Text="Заглушка: сюда будет добавлен код анализа БД (50% чаще добавленные в корзину + 50% чаще купленные)." Foreground="{StaticResource TextMutedBrush}" Margin="4,0,0,14"/>

                <ItemsControl x:Name="PopularBooksItemsControl" Margin="0,0,0,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BookCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="220"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" CornerRadius="12" Background="#EEF2FF">
                                        <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="44" Foreground="{StaticResource TextMainBrush}"/>
                                        <TextBlock Text="{Binding Author}" Margin="0,4,0,8" Foreground="{StaticResource TextMutedBrush}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}">
                                                <Run Text="{Binding Price}"/><Run Text=" ₽"/>
                                            </TextBlock>
                                            <Button Grid.Column="1" Content="Купить" Style="{StaticResource BuyButtonStyle}" Tag="{Binding BookID}" Click="BuyButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="📚 Жанры" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" Margin="4,0,0,12"/>
                <TextBlock Text="Заглушка: жанры и книги будут приходить из БД в следующих версиях." Foreground="{StaticResource TextMutedBrush}" Margin="4,0,0,14"/>

                <ItemsControl x:Name="GenresItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="18" Padding="16" Margin="0,0,0,18" BorderBrush="#DDE4FF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding GenreName}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Books}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource BookCardStyle}" Width="200" Height="360">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="180"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" Background="#EEF2FF" CornerRadius="12">
                                                            <Image Source="{Binding CoverImage}" Stretch="UniformToFill"/>
                                                        </Border>
                                                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="40"/>
                                                            <TextBlock Text="{Binding Author}" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,6"/>
                                                            <TextBlock Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="Bold">
                                                                <Run Text="{Binding Price}"/><Run Text=" ₽"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
