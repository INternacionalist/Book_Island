<Window x:Class="WpfAppBookStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин Книг" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BuyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E85D2A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D04D1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F5F5F5" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Width="50" Height="50" Background="Transparent"
                        BorderThickness="2" BorderBrush="#333" Margin="0,0,20,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate>
                            <Border Background="Transparent" BorderBrush="#333" BorderThickness="2" CornerRadius="8">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Border Grid.Column="1" Background="White" CornerRadius="25"
                        BorderBrush="#DDD" BorderThickness="2" Height="50">
                    <TextBox x:Name="SearchBox"
                             Text="Поиск..."
                             VerticalAlignment="Center"
                             Padding="20,0"
                             FontSize="16"
                             BorderThickness="0"
                             GotFocus="SearchBox_GotFocus"
                             Foreground="#666"/>
                </Border>

                <Button x:Name="ThemeBtn" Grid.Column="2" Content="🌙 тема" Margin="20,0,10,0"
                        Style="{StaticResource HeaderButtonStyle}" Click="ThemeBtn_Click"/>

                <Button Grid.Column="3" Content="👤 логин" Margin="0,0,10,0"
                        Style="{StaticResource HeaderButtonStyle}" Click="reg"/>

                <Button Grid.Column="4" Content="🛒 корзина" Width="120"
                        Style="{StaticResource HeaderButtonStyle}" Click="CartButton_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>
                <Border x:Name="CartPanel" Background="#F3F4F6" CornerRadius="20" Padding="16" Margin="0,10,0,20" Visibility="Collapsed">
                    <StackPanel>
                        <DockPanel>
                            <CheckBox x:Name="SelectAllCheckBox" Content="Выбрать все" FontSize="20" FontWeight="SemiBold"
                                      VerticalAlignment="Center" Click="SelectAllCheckBox_Click"/>
                            <Border Background="#E5E7EB" CornerRadius="14" Padding="10,4" DockPanel.Dock="Right">
                                <TextBlock x:Name="CartCountBadge" Text="0" FontWeight="Bold" Foreground="#111827"/>
                            </Border>
                        </DockPanel>

                        <TextBlock x:Name="CartEmptyText" Text="Корзина пока пустая" Foreground="#6B7280" FontSize="16" Margin="0,16,0,0"/>

                        <ItemsControl x:Name="CartItemsControl" Margin="0,16,0,0" Visibility="Collapsed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="16" Padding="14" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0" VerticalAlignment="Top" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      Margin="0,6,10,0" Click="ItemSelectionChanged"/>

                                            <Border Grid.Column="1" Width="72" Height="96" CornerRadius="10" Background="#F3F4F6">
                                                <Image Source="{Binding CoverURL}" Stretch="UniformToFill"/>
                                            </Border>

                                            <StackPanel Grid.Column="2" Margin="12,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <Border Background="#FCE7F3" CornerRadius="8" Padding="8,2" Margin="0,8,0,0" HorizontalAlignment="Left">
                                                    <TextBlock Text="% Скидка от 2 ед" Foreground="#DB2777" FontWeight="SemiBold" FontSize="12"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding CurrentUnitPrice, StringFormat={}{0:0.##} ₽}" FontSize="22" FontWeight="Bold" Foreground="#16A34A"/>
                                                <TextBlock Text="{Binding OldUnitPrice, StringFormat={}{0:0.##} ₽}" Foreground="#9CA3AF" TextDecorations="Strikethrough"/>
                                            </StackPanel>

                                            <Border Grid.Column="4" Background="#F3F4F6" CornerRadius="12" Padding="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="−" Width="32" Height="32" FontSize="18" FontWeight="Bold" BorderThickness="0"
                                                            Background="Transparent" Cursor="Hand" Click="DecreaseQuantity_Click"/>
                                                    <TextBlock Text="{Binding Quantity}" Width="40" VerticalAlignment="Center" TextAlignment="Center" FontWeight="Bold" FontSize="16"/>
                                                    <Button Content="+" Width="32" Height="32" FontSize="18" FontWeight="Bold" BorderThickness="0"
                                                            Background="Transparent" Cursor="Hand" Click="IncreaseQuantity_Click"/>
                                                </StackPanel>
                                            </Border>

                                            <Button Grid.Column="5" Content="🗑" Width="38" Height="38" Margin="12,0,0,0" VerticalAlignment="Top"
                                                    Background="#F3F4F6" BorderThickness="0" Cursor="Hand" Click="RemoveItem_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="CartTotalText" Text="Итого: 0 ₽" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Button Content="🔥 популярные ->"
                        HorizontalAlignment="Left"
                        Margin="10,0,0,20"
                        Background="Transparent"
                        BorderBrush="#333"
                        BorderThickness="2"
                        Padding="15,8"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <ItemsControl x:Name="BooksItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BookCardStyle}" Width="250" Height="420">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="280"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="6" Margin="0,0,0,15">
                                        <Image Source="{Binding CoverURL}"
                                               Stretch="Uniform"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Row="1">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="45"
                                                   Margin="0,0,0,5"
                                                   Foreground="#333"/>

                                        <TextBlock Text="{Binding Author}"
                                                   FontSize="13"
                                                   Foreground="#666"
                                                   Margin="0,0,0,10"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock FontSize="20"
                                                           FontWeight="Bold"
                                                           Foreground="#FF6B35">
                                                    <Run Text="{Binding Price}"/>
                                                    <Run Text=" ₽" FontSize="16"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Content="Купить"
                                                    Style="{StaticResource BuyButtonStyle}"
                                                    Click="BuyButton_Click"
                                                    Tag="{Binding BookID}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
