<Window x:Class="WpfAppBookStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин Книг" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Стиль для карточки книги -->
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки "Купить" -->
        <Style x:Key="BuyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E85D2A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D04D1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F5F5F5" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопка меню -->
                <Button Grid.Column="0" Width="50" Height="50" Background="Transparent" 
                        BorderThickness="2" BorderBrush="#333" Margin="0,0,20,0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate>
                            <Border Background="Transparent" BorderBrush="#333" BorderThickness="2" CornerRadius="8">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                    <Rectangle Width="25" Height="3" Fill="#333" Margin="0,3"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Поиск -->
                <Border Grid.Column="1" Background="White" CornerRadius="25" 
                        BorderBrush="#DDD" BorderThickness="2" Height="50">
                    <TextBox x:Name="SearchBox" 
                             Text="Поиск..." 
                             VerticalAlignment="Center" 
                             Padding="20,0" 
                             FontSize="16" 
                             BorderThickness="0"
                             GotFocus="SearchBox_GotFocus"
                             Foreground="#666"/>
                </Border>

                <!-- Кнопка темы -->
                <Button x:Name="ThemeBtn" Grid.Column="2" Content="🌙 тема" 
                        Width="100" Height="50" Margin="20,0"
                        Background="Transparent" BorderBrush="#333" BorderThickness="2"
                        FontSize="14" Cursor="Hand" Click="ThemeBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Кнопка логина -->
                <Button Grid.Column="3" Content="👤 логин" 
                        Width="100" Height="50"
                        Background="Transparent" BorderBrush="#333" BorderThickness="2"
                        FontSize="14" Cursor="Hand" Click="reg">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>
                <!-- Заголовок секции -->
                <Button Content="🔥 популярные ->" 
                        HorizontalAlignment="Left" 
                        Margin="10,20,0,20"
                        Background="Transparent" 
                        BorderBrush="#333" 
                        BorderThickness="2" 
                        Padding="15,8" 
                        FontSize="16" 
                        FontWeight="Bold"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Каталог книг -->
                <ItemsControl x:Name="BooksItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Карточка книги -->
                            <Border Style="{StaticResource BookCardStyle}" Width="250" Height="420">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="280"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Обложка книги -->
                                    <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="6" Margin="0,0,0,15">
                                        <Image Source="{Binding CoverURL}" 
                                               Stretch="Uniform" 
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- Информация о книге -->
                                    <StackPanel Grid.Row="1">
                                        <!-- Название -->
                                        <TextBlock Text="{Binding Title}" 
                                                   FontSize="16" 
                                                   FontWeight="SemiBold" 
                                                   TextWrapping="Wrap" 
                                                   MaxHeight="45"
                                                   Margin="0,0,0,5"
                                                   Foreground="#333"/>

                                        <!-- Автор -->
                                        <TextBlock Text="{Binding Author}" 
                                                   FontSize="13" 
                                                   Foreground="#666"
                                                   Margin="0,0,0,10"/>

                                        <!-- Цена и кнопка -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Цена -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock FontSize="20" 
                                                           FontWeight="Bold" 
                                                           Foreground="#FF6B35">
                                                    <Run Text="{Binding Price}"/>
                                                    <Run Text=" ₽" FontSize="16"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Кнопка купить -->
                                            <Button Grid.Column="1" 
                                                    Content="Купить" 
                                                    Style="{StaticResource BuyButtonStyle}"
                                                    Click="BuyButton_Click"
                                                    Tag="{Binding BookID}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
